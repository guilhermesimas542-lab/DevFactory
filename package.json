{
  "name": "devfactory",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "electron:dev": "concurrently \"npm run dev --workspace=web\" \"wait-on http://localhost:3000 && electron apps/electron/src/main.js\"",
    "electron:build": "npm run build --workspace=web && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "wait-on": "^7.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
