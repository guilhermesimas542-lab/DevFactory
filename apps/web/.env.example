# Frontend Configuration (apps/web/.env.example)

# API URL — Aponta para o backend Express
# Local: http://localhost:5000
# Production (Railway): https://{railway-app-name}.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:5000

# NextAuth Configuration
# Local: http://localhost:3000
# Production (Vercel): https://{your-vercel-domain}.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Secret para assinar JWT (gerar com: openssl rand -base64 32)
# Deve ser diferente em produção
NEXTAUTH_SECRET=generate-random-secret-here

# GitHub Token (para análise futura de repositórios)
# Obtém em: https://github.com/settings/tokens
NEXT_PUBLIC_GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxx
