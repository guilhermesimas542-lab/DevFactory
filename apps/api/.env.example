# Backend Configuration (apps/api/.env.example)

# Database Connection
# Local (SQLite): file:./dev.db
# Local (PostgreSQL): postgresql://user:password@localhost:5432/devfactory
# Production (Railway): postgresql://user:password@postgres.railway.internal:5432/railway
DATABASE_URL="postgresql://user:password@localhost:5432/devfactory"

# Node Environment
# development | production
NODE_ENV=development

# Server Port
PORT=5000

# CORS (permitir requisições do frontend)
# Local: http://localhost:3000
# Production: https://seu-dominio-vercel.vercel.app
CORS_ORIGIN=http://localhost:3000
